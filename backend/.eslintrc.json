{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "airbnb-base",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "import/prefer-default-export": "off",
    "no-unused-vars": "warn",
    "prefer-const": "warn",
    "no-underscore-dangle": ["error", { "allow": ["_id"] }]
  }
}
